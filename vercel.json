{
  "buildCommand": "vite build",
  "rewrites": [
    {"source": "/share/:path*", "destination": "/index.html"},
    {"source": "/report/:path*", "destination": "/index.html"}
  ],
  "headers": [
    {
      "source": "/share/:path*",
      "headers": [
        {"key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet"}
      ]
    },
    {
      "source": "/report/:path*",
      "headers": [
        {"key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet"}
      ]
    }
  ]
}
